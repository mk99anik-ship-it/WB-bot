# Получить у @BotFather
BOT_TOKEN=your_bot_token_here

# Ваш Telegram ID (для уведомлений об ошибках и статистике)
ADMIN_ID=123456789

# Стоимость подписки в Telegram Stars (1 Star ≈ 0.013 USD)
# 100 Stars ≈ ~130 руб/месяц
SUBSCRIPTION_PRICE_STARS=100
SUBSCRIPTION_DAYS=30

# Бесплатный лимит: кол-во товаров для отслеживания
FREE_ITEMS_LIMIT=1
# Платный лимит
PAID_ITEMS_LIMIT=20

# Интервал проверки цен (в минутах)
# Для бесплатных пользователей
FREE_CHECK_INTERVAL=120
# Для платных пользователей
PAID_CHECK_INTERVAL=30

# Путь к базе данных
DATABASE_URL=sqlite+aiosqlite:///./wb_monitor.db
